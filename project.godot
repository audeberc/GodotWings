; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="GodotWings"
config/description="Open-source fixed-wing flight simulator with ArduPilot SITL integration."
run/main_scene="res://examples/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[debug]

settings/stdout/verbose_stdout=true

[editor_plugins]

enabled=PackedStringArray("res://addons/godotwings/plugin.cfg")

[physics]

common/physics_ticks_per_second=50

[rendering]

textures/canvas_textures/default_texture_repeat=1
textures/vram_compression/import_etc2_astc=true
